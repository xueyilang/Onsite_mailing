# ===== Quick Microsoft 365 test =====
# Fill these first if you only want to test device code login + send mail.
GRAPH_TENANT_ID=common
# Optional. Leave empty to use Microsoft's public Azure CLI client id for device code login.
GRAPH_CLIENT_ID=
TEST_MAIL_TO=marco.xue@alpha-ess.de
TEST_MAIL_SUBJECT=test
TEST_MAIL_BODY=这是一封自动生成的邮件。

# ===== Feishu / Lark =====
# Fill these later for the full Feishu report workflow.
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_TOKEN=bascnxxxxxxxx
FEISHU_TABLE_ID=tblxxxxxxxx
FEISHU_VIEW_ID=
FEISHU_PAGE_SIZE=100
EXPORT_FIELDS=Case ID,Customer,Status,Owner,Due Date

# ===== Full report mail settings =====
MAIL_TO=alice@example.com,bob@example.com
MAIL_CC=manager@example.com
MAIL_SUBJECT_TEMPLATE=[Daily Report] {date}
MAIL_BODY_TEMPLATE=Hello,<br><br>Please find the attached report for {date}.<br><br>Regards,<br>{sender_name}
MAIL_SENDER_NAME=Marco
REPORT_FILE_PREFIX=feishu_report
